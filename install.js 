// acode-ai-assistant/install.js
// Installation script for Acode AI Assistant

const fs = require('fs');
const path = require('path');

const PLUGIN_NAME = "acode-ai-assistant";
const PLUGIN_VERSION = "1.0.0";

console.log(`Installing ${PLUGIN_NAME} v${PLUGIN_VERSION}...`);

// Create plugin directory
const pluginDir = path.join('/sdcard/Acode/plugins', PLUGIN_NAME);
if (!fs.existsSync(pluginDir)) {
    fs.mkdirSync(pluginDir, { recursive: true });
    console.log(`Created plugin directory: ${pluginDir}`);
}

// Copy files
const filesToCopy = ['main.js', 'plugin.json', 'icon.png', 'README.md'];
filesToCopy.forEach(file => {
    if (fs.existsSync(file)) {
        fs.copyFileSync(file, path.join(pluginDir, file));
        console.log(`Copied: ${file}`);
    }
});

console.log('\n✅ Installation complete!');
console.log('Restart Acode to activate the plugin.');
console.log('\n📝 Next steps:');
console.log('1. Open Acode settings');
console.log('2. Go to AI Coding Assistant settings');
console.log('3. Enter your OpenAI API key');
console.log('4. Start using AI assistance!');