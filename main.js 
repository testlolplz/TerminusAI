// Settings UI Extension
class AISettingsUI {
    constructor() {
        this.container = null;
    }
    
    render() {
        this.container = document.createElement('div');
        this.container.className = 'ai-settings-panel';
        this.container.innerHTML = `
            <div class="settings-section">
                <h3>🤖 AI Coding Assistant Settings</h3>
                
                <div class="setting-item">
                    <label>API Key (OpenAI)</label>
                    <input type="password" id="ai-api-key" placeholder="sk-..." />
                    <small>Get your API key from <a href="https://platform.openai.com/api-keys" target="_blank">OpenAI Platform</a></small>
                </div>
                
                <div class="setting-item">
                    <label>Model</label>
                    <select id="ai-model">
                        <option value="gpt-3.5-turbo">GPT-3.5 Turbo (Fast, Cheap)</option>
                        <option value="gpt-4">GPT-4 (Powerful, Expensive)</option>
                        <option value="gpt-3.5-turbo-16k">GPT-3.5 16K (Long Context)</option>
                    </select>
                </div>
                
                <div class="setting-item">
                    <label>Temperature (Creativity)</label>
                    <input type="range" id="ai-temperature" min="0" max="2" step="0.1" value="0.7" />
                    <span id="temperature-value">0.7</span>
                    <small>Lower = more focused, Higher = more creative</small>
                </div>
                
                <div class="setting-item">
                    <label>
                        <input type="checkbox" id="ai-autocomplete" checked />
                        Enable Auto-Complete
                    </label>
                </div>
                
                <div class="setting-item">
                    <label>Custom Commands</label>
                    <textarea id="ai-custom-commands" rows="5" placeholder='[{"trigger": "fix", "prompt": "Fix this code:"}]'></textarea>
                    <small>JSON format for custom commands</small>
                </div>
                
                <button id="ai-save-settings" class="btn btn-primary">Save Settings</button>
                <button id="ai-test-connection" class="btn btn-secondary">Test Connection</button>
            </div>
        `;
        
        // Load saved settings
        this.loadSettings();
        
        // Add event listeners
        this.container.querySelector('#ai-temperature').addEventListener('input', (e) => {
            this.container.querySelector('#temperature-value').textContent = e.target.value;
        });
        
        this.container.querySelector('#ai-save-settings').addEventListener('click', () => {
            this.saveSettings();
        });
        
        this.container.querySelector('#ai-test-connection').addEventListener('click', () => {
            this.testConnection();
        });
        
        return this.container;
    }
    
    loadSettings() {
        if (localStorage) {
            this.container.querySelector('#ai-api-key').value = localStorage.getItem('ai_api_key') || '';
            this.container.querySelector('#ai-model').value = localStorage.getItem('ai_model') || 'gpt-3.5-turbo';
            this.container.querySelector('#ai-temperature').value = localStorage.getItem('ai_temperature') || '0.7';
            this.container.querySelector('#temperature-value').textContent = localStorage.getItem('ai_temperature') || '0.7';
            this.container.querySelector('#ai-autocomplete').checked = localStorage.getItem('ai_autocomplete') !== 'false';
            this.container.querySelector('#ai-custom-commands').value = localStorage.getItem('ai_custom_commands') || '[]';
        }
    }
    
    saveSettings() {
        if (localStorage) {
            localStorage.setItem('ai_api_key', this.container.querySelector('#ai-api-key').value);
            localStorage.setItem('ai_model', this.container.querySelector('#ai-model').value);
            localStorage.setItem('ai_temperature', this.container.querySelector('#ai-temperature').value);
            localStorage.setItem('ai_autocomplete', this.container.querySelector('#ai-autocomplete').checked);
            localStorage.setItem('ai_custom_commands', this.container.querySelector('#ai-custom-commands').value);
            
            alert('Settings saved! Restart the plugin to apply changes.');
        }
    }
    
    async testConnection() {
        const apiKey = this.container.querySelector('#ai-api-key').value;
        if (!apiKey) {
            alert('Please enter an API key first');
            return;
        }
        
        const testButton = this.container.querySelector('#ai-test-connection');
        testButton.textContent = 'Testing...';
        testButton.disabled = true;
        
        try {
            const response = await fetch('https://api.openai.com/v1/chat/completions', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${apiKey}`
                },
                body: JSON.stringify({
                    model: 'gpt-3.5-turbo',
                    messages: [{ role: 'user', content: 'Say "Connection successful!"' }],
                    max_tokens: 20
                })
            });
            
            if (response.ok) {
                alert('✅ Connection successful! Your API key is working.');
            } else {
                const error = await response.json();
                alert(`❌ Connection failed: ${error.error?.message || 'Unknown error'}`);
            }
        } catch (error) {
            alert(`❌ Connection failed: ${error.message}`);
        } finally {
            testButton.textContent = 'Test Connection';
            testButton.disabled = false;
        }
    }
}

