// Acode Plugin: AI Coding Assistant - Complete Plugin Structure

"use strict";

// Plugin Metadata
const pluginName = "AI Coding Assistant";
const pluginVersion = "1.0.0";
const pluginAuthor = "TPF Team";
const pluginDescription = "AI-powered coding assistant with code completion, explanation, debugging, and chat features";

// Plugin Configuration
const CONFIG = {
    apiEndpoint: "https://api.openai.com/v1/chat/completions", // Default, can be changed
    apiKey: "", // User will input their API key
    model: "gpt-3.5-turbo",
    temperature: 0.7,
    maxTokens: 2000,
    theme: "dark",
    autoComplete: true,
    autoCompleteDelay: 500,
    maxHistorySize: 50,
    supportedLanguages: ["javascript", "python", "php", "html", "css", "java", "cpp", "csharp", "go", "rust", "ruby", "swift"]
};

// Main Plugin Class
class AICodingAssistant {
    constructor() {
        this.editor = null;
        this.history = [];
        this.isEnabled = true;
        this.autoCompleteTimeout = null;
        this.conversationHistory = [];
        this.uiElements = {};
        this.customCommands = this.loadCustomCommands();
        
        // Initialize the plugin
        this.init();
    }
    
    async init() {
        console.log(`[${pluginName}] Initializing v${pluginVersion}`);
        
        // Wait for Acode to be ready
        if (window.acode) {
            this.setupEditor();
            this.createUI();
            this.registerCommands();
            this.loadSettings();
            this.setupEventListeners();
        } else {
            // Wait for acode to load
            window.addEventListener('acode-ready', () => {
                this.setupEditor();
                this.createUI();
                this.registerCommands();
                this.loadSettings();
                this.setupEventListeners();
            });
        }
    }
    
    setupEditor() {
        // Get the active editor instance
        this.editor = editorManager?.getActive();
        
        if (this.editor) {
            this.setupAutoComplete();
            this.addEditorListeners();
        }
        
        // Listen for editor changes
        if (editorManager) {
            editorManager.on('active-change', (editor) => {
                this.editor = editor;
                this.setupAutoComplete();
            });
        }
    }
    
    setupAutoComplete() {
        if (!this.editor || !CONFIG.autoComplete) return;
        
        // Remove existing listeners to avoid duplicates
        if (this.editor.off) {
            this.editor.off('change', this.autoCompleteHandler);
        }
        
        // Add auto-complete listener
        this.autoCompleteHandler = this.handleAutoComplete.bind(this);
        this.editor.on('change', this.autoCompleteHandler);
    }
    
    handleAutoComplete() {
        if (!CONFIG.autoComplete) return;
        
        // Clear previous timeout
        if (this.autoCompleteTimeout) {
            clearTimeout(this.autoCompleteTimeout);
        }
        
        // Get current cursor position and line
        const cursor = this.editor.getCursor();
        const line = this.editor.getLine(cursor.line);
        const currentText = line.substring(0, cursor.ch);
        
        // Check if we should trigger auto-complete
        const triggerPatterns = ['.', '->', '::', '=', ' ', '(', '{', '['];
        const lastChar = currentText.slice(-1);
        
        if (triggerPatterns.includes(lastChar) && currentText.length > 2) {
            this.autoCompleteTimeout = setTimeout(() => {
                this.getAIAutoComplete(currentText);
            }, CONFIG.autoCompleteDelay);
        }
    }
    
    async getAIAutoComplete(currentText) {
        try {
            const fileType = this.getCurrentFileType();
            const context = this.getCodeContext();
            
            const prompt = `Complete this ${fileType} code. Only return the completion, no explanations:\n\n${context}\n${currentText}`;
            
            const response = await this.callAI(prompt, {
                maxTokens: 100,
                temperature: 0.5
            });
            
            if (response && response.trim()) {
                this.showAutoCompleteSuggestion(response);
            }
        } catch (error) {
            console.error('Auto-complete error:', error);
        }
    }
    
    showAutoCompleteSuggestion(suggestion) {
        // Create or update suggestion widget
        if (!this.suggestionWidget) {
            this.suggestionWidget = document.createElement('div');
            this.suggestionWidget.className = 'ai-suggestion-widget';
            this.suggestionWidget.style.cssText = `
                position: absolute;
                background: #2d2d2d;
                color: #a9b7c6;
                padding: 4px 8px;
                border-radius: 4px;
                font-family: monospace;
                font-size: 12px;
                z-index: 1000;
                opacity: 0.7;
                cursor: pointer;
                border-left: 3px solid #4CAF50;
            `;
            document.body.appendChild(this.suggestionWidget);
        }
        
        // Position at cursor
        const cursor = this.editor.getCursor();
        const coords = this.editor.cursorCoords(cursor, 'page');
        this.suggestionWidget.style.top = `${coords.bottom + 5}px`;
        this.suggestionWidget.style.left = `${coords.left}px`;
        this.suggestionWidget.textContent = suggestion.substring(0, 100);
        this.suggestionWidget.style.display = 'block';
        
        // Hide after 3 seconds
        setTimeout(() => {
            if (this.suggestionWidget) {
                this.suggestionWidget.style.display = 'none';
            }
        }, 3000);
    }
    
    getCodeContext() {
        if (!this.editor) return '';
        
        const cursor = this.editor.getCursor();
        const startLine = Math.max(0, cursor.line - 20);
        const endLine = Math.min(this.editor.lineCount() - 1, cursor.line + 10);
        
        let context = '';
        for (let i = startLine; i <= endLine; i++) {
            context += this.editor.getLine(i) + '\n';
        }
        
        return context;
    }
    
    getCurrentFileType() {
        const activeFile = editorManager?.getActiveFile();
        if (activeFile && activeFile.name) {
            const extension = activeFile.name.split('.').pop();
            const languageMap = {
                'js': 'javascript', 'py': 'python', 'php': 'php',
                'html': 'html', 'css': 'css', 'java': 'java',
                'cpp': 'cpp', 'c': 'c', 'go': 'go', 'rs': 'rust',
                'rb': 'ruby', 'swift': 'swift', 'json': 'json',
                'md': 'markdown', 'xml': 'xml', 'sql': 'sql'
            };
            return languageMap[extension] || 'code';
        }
        return 'code';
    }
    
    createUI() {
        // Create plugin button in sidebar
        this.createSidebarButton();
        
        // Create main chat panel
        this.createChatPanel();
        
        // Create floating action button
        this.createFAB();
        
        // Add status bar indicator
        this.addStatusBarIndicator();
    }
    
